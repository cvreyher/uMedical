{
  "$schema": "https://json.schemastore.org/nest-cli",
  "collection": "@nestjs/schematics",
  "sourceRoot": "src",
  "compilerOptions": {
    "tsConfigPath": "tsconfig.app.json",
    "deleteOutDir": true,
    "builder": {
      "type": "swc",
      "options": {
        "swcrcPath": ".swcrc"
      }
    },
    "typeCheck": true,
    "plugins": [
      {
        "name": "@nestjs/swagger",
        "options": {
          "classValidatorShim": true,
          "introspectComments": true,
          "esmCompatible": true,
          "dtoFileNameSuffix": [".dto.ts", ".command.ts", ".query.ts"],
          "controllerFileNameSuffix": [".controller.ts"],
          "dtoKeyOfComment": "description",
          "controllerKeyOfComment": "summary",
          "persistSchemaPath": true
        }
      }
    ]
  },
  "watchOptions": {
    "watch": ["src"],
    "ignore": [
      "**/*.spec.ts",
      "dist",
      "node_modules",
      "coverage",
      "*.log",
      "*.pid",
      ".temp",
      ".tmp",
      "src/metadata.ts",
      "src/metadata.d.ts",
      "metadata.ts",
      "metadata.d.ts"
    ],
    "usePolling": false,
    "atomic": false,
    "awaitWriteFinish": {
      "stabilityThreshold": 500,
      "pollInterval": 100
    },
    "ignoreInitial": true
  }
}
