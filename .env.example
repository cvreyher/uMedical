# Environment Configuration
# Copy this file to .env and modify as needed

# App environment
NODE_ENV=development

# App port
PORT=3000

# Database connection string (matches `pnpm infra:up` Docker Postgres)
DATABASE_URL=postgres://postgres:postgres@localhost:5433/nestjs

# Database connection pool config
DB_POOL_MAX=20
DB_POOL_MIN=5
DB_POOL_IDLE_TIMEOUT=30000
DB_POOL_CONNECTION_TIMEOUT=10000

# Redis (matches `pnpm infra:up` Docker Redis)
REDIS_HOST=localhost
REDIS_PORT=6380
# REDIS_PASSWORD=
REDIS_TTL=3600

# Admin API key: protects admin endpoints (imports, feeds, RAG jobs) via the
# x-api-key header. Min 16 characters. Unset: admin endpoints are open in
# development but DISABLED in production.
# ADMIN_API_KEY=change-me-to-a-long-random-string

# Background live data fetching (EMA/FDA/MHRA feeds, EPI downloads, OpenAI embeddings).
# Keep "false" in local development to avoid rate limits - work with seeded data
# instead (pnpm db:seed:dev). Set "true" to let the cron jobs fetch live data.
# Manual admin endpoints (e.g. POST /ema/import) work regardless of this flag,
# but queued jobs are only processed while this is "true".
LIVE_FETCH_ENABLED=false

# OpenAI API (for RAG embeddings - only needed when LIVE_FETCH_ENABLED=true)
# OPENAI_API_KEY=sk-...

# Cloudflare R2 Storage (for document storage - optional)
# R2_ACCOUNT_ID=
# R2_ACCESS_KEY_ID=
# R2_SECRET_ACCESS_KEY=
# R2_BUCKET_NAME=umedical-documents


# API Configuration
# API server URL (required)
API_UPSTREAM_BASE_URL=http://localhost:3000


# Mock Configuration
# Enable API Mock (optional, "true" or "false")
NEXT_PUBLIC_ENABLE_API_MOCKING=false

# Mock API server port (optional, default 8080)
NEXT_PUBLIC_MOCK_API_PORT=8080

# App Configuration
# App URL (optional, default http://localhost:3000)
NEXT_PUBLIC_API_URL=http://localhost:8000/api/proxy
